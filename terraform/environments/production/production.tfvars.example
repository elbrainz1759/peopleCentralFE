# ─────────────────────────────────────────────────────────────
# Copy this to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────

aws_region        = "us-east-1"
environment       = "production"
app_name          = "people-central-fe"
ec2_instance_type = "t3.micro"

# Ubuntu 22.04 LTS - us-east-1
ec2_ami = "ami-0c7217cdde317cfec"

# The name of the key pair you already have in AWS console
# EC2 → Key Pairs → create one if you don't have it
key_pair_name = "your-key-pair-name"

# Restrict SSH to your IP only for security
# Find your IP: curl ifconfig.me
allowed_ssh_cidr = "YOUR_IP/32"
